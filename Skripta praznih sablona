## PRIMER 2: SQLite CRUD forma

Scenario: forma sa dva polja i checkbox-om, dugme "Dodaj" koje upisuje unos u lokalnu bazu, i lista ispod koja prikazuje sve unose iz baze.

STEP 1 - Model klasa. Cetiri polja: id (automatski ga daje baza), naziv, opis, zavrsen (boolean):

```
package com.example.myapplication;

public class Zadatak {

private int id;
private String naziv;
private String opis;
private boolean zavrsen;

public Zadatak() {}

public Zadatak(String naziv, String opis, boolean zavrsen) {
this.naziv = naziv;
this.opis = opis;
this.zavrsen = zavrsen;
}

public int getId() { return id; }
public void setId(int id) { this.id = id; }
public String getNaziv() { return naziv; }
public void setNaziv(String naziv) { this.naziv = naziv; }
public String getOpis() { return opis; }
public void setOpis(String opis) { this.opis = opis; }
public boolean isZavrsen() { return zavrsen; }
public void setZavrsen(boolean zavrsen) { this.zavrsen = zavrsen; }
}
```

STEP 2 - DatabaseHelper. Ovo je klasa koja pravi tabelu (onCreate) i sadrzi sve metode za rad sa bazom (insert, citanje svih redova, brisanje, izmena) - nema posebne DAO klase, sve je ovde:

```
package com.example.myapplication;

import android.content.ContentValues;
import android.content.Context;
import android.database.Cursor;
import android.database.sqlite.SQLiteDatabase;
import android.database.sqlite.SQLiteOpenHelper;
import java.util.ArrayList;
import java.util.List;

public class DatabaseHelper extends SQLiteOpenHelper {

private static final String DATABASE_NAME = "mojabaza.db";
private static final int DATABASE_VERSION = 1;
private static final String TABLE_ZADACI = "zadaci";
private static final String COLUMN_ID = "id";
private static final String COLUMN_NAZIV = "naziv";
private static final String COLUMN_OPIS = "opis";
private static final String COLUMN_ZAVRSEN = "zavrsen";

public DatabaseHelper(Context context) {
super(context, DATABASE_NAME, null, DATABASE_VERSION);
}

@Override
public void onCreate(SQLiteDatabase db) {
String createTable = "CREATE TABLE " + TABLE_ZADACI + " (" +
COLUMN_ID + " INTEGER PRIMARY KEY AUTOINCREMENT, " +
COLUMN_NAZIV + " TEXT, " +
COLUMN_OPIS + " TEXT, " +
COLUMN_ZAVRSEN + " INTEGER)";
db.execSQL(createTable);
}

@Override
public void onUpgrade(SQLiteDatabase db, int oldVersion, int newVersion) {
db.execSQL("DROP TABLE IF EXISTS " + TABLE_ZADACI);
onCreate(db);
}

public long insertZadatak(Zadatak zadatak) {
SQLiteDatabase db = this.getWritableDatabase();
ContentValues values = new ContentValues();
values.put(COLUMN_NAZIV, zadatak.getNaziv());
values.put(COLUMN_OPIS, zadatak.getOpis());
values.put(COLUMN_ZAVRSEN, zadatak.isZavrsen() ? 1 : 0);
long id = db.insert(TABLE_ZADACI, null, values);
db.close();
return id;
}

public List<Zadatak> getAllZadaci() {
List<Zadatak> lista = new ArrayList<>();
SQLiteDatabase db = this.getReadableDatabase();
Cursor cursor = db.query(TABLE_ZADACI, null, null, null, null, null, null);
if (cursor.moveToFirst()) {
do {
Zadatak z = new Zadatak();
z.setId(cursor.getInt(cursor.getColumnIndexOrThrow(COLUMN_ID)));
z.setNaziv(cursor.getString(cursor.getColumnIndexOrThrow(COLUMN_NAZIV)));
z.setOpis(cursor.getString(cursor.getColumnIndexOrThrow(COLUMN_OPIS)));
z.setZavrsen(cursor.getInt(cursor.getColumnIndexOrThrow(COLUMN_ZAVRSEN)) == 1);
lista.add(z);
} while (cursor.moveToNext());
}
cursor.close();
db.close();
return lista;
}

public void deleteZadatak(int id) {
SQLiteDatabase db = this.getWritableDatabase();
db.delete(TABLE_ZADACI, COLUMN_ID + "=?", new String[]{String.valueOf(id)});
db.close();
}

public void updateZadatak(Zadatak zadatak) {
SQLiteDatabase db = this.getWritableDatabase();
ContentValues values = new ContentValues();
values.put(COLUMN_NAZIV, zadatak.getNaziv());
values.put(COLUMN_OPIS, zadatak.getOpis());
values.put(COLUMN_ZAVRSEN, zadatak.isZavrsen() ? 1 : 0);
db.update(TABLE_ZADACI, values, COLUMN_ID + "=?", new String[]{String.valueOf(zadatak.getId())});
db.close();
}
}
```

STEP 3 - MainActivity. Cita polja sa forme, cuva u bazu preko DatabaseHelper-a, i odmah osvezava listu ispod pozivom osveziListu():

```
package com.example.myapplication;

import android.os.Bundle;
import android.view.View;
import android.widget.ArrayAdapter;
import android.widget.Button;
import android.widget.CheckBox;
import android.widget.EditText;
import android.widget.ListView;
import android.widget.Toast;
import androidx.appcompat.app.AppCompatActivity;
import java.util.ArrayList;
import java.util.List;

public class MainActivity extends AppCompatActivity {

private EditText etNaziv, etOpis;
private CheckBox cbZavrsen;
private Button btnDodaj;
private ListView listView;
private DatabaseHelper dbHelper;
private ArrayAdapter<String> adapter;

@Override
protected void onCreate(Bundle savedInstanceState) {
super.onCreate(savedInstanceState);
setContentView(R.layout.activity_main);
if (getSupportActionBar() != null) getSupportActionBar().hide();

etNaziv = findViewById(R.id.etNaziv);
etOpis = findViewById(R.id.etOpis);
cbZavrsen = findViewById(R.id.cbZavrsen);
btnDodaj = findViewById(R.id.btnDodaj);
listView = findViewById(R.id.listView);

dbHelper = new DatabaseHelper(this);
adapter = new ArrayAdapter<>(this, android.R.layout.simple_list_item_1, new ArrayList<String>());
listView.setAdapter(adapter);

osveziListu();

btnDodaj.setOnClickListener(new View.OnClickListener() {
@Override
public void onClick(View v) {
String naziv = etNaziv.getText().toString();
String opis = etOpis.getText().toString();
boolean zavrsen = cbZavrsen.isChecked();

if (naziv.isEmpty()) {
Toast.makeText(MainActivity.this, "Unesi naziv", Toast.LENGTH_SHORT).show();
return;
}

Zadatak zadatak = new Zadatak(naziv, opis, zavrsen);
dbHelper.insertZadatak(zadatak);

etNaziv.setText("");
etOpis.setText("");
cbZavrsen.setChecked(false);

osveziListu();
}
});
}

private void osveziListu() {
List<Zadatak> lista = dbHelper.getAllZadaci();
List<String> prikaz = new ArrayList<>();
for (Zadatak z : lista) {
prikaz.add(z.getNaziv() + " - " + (z.isZavrsen() ? "Zavrsen" : "Nije zavrsen"));
}
adapter.clear();
adapter.addAll(prikaz);
adapter.notifyDataSetChanged();
}
}
```

