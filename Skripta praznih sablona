adapter = new ArrayAdapter<>(this, android.R.layout.simple_list_item_1, new ArrayList<String>());
listView.setAdapter(adapter);
osveziListu();

btnSlikaj.setOnClickListener(new View.OnClickListener() {
@Override
public void onClick(View v) {
dispatchTakePictureIntent();
}
});

btnSacuvaj.setOnClickListener(new View.OnClickListener() {
@Override
public void onClick(View v) {
String naziv = etNaziv.getText().toString();
if (naziv.isEmpty() || currentPhotoPath == null) {
Toast.makeText(MainActivity.this, "Unesi naziv i slikaj prvo", Toast.LENGTH_SHORT).show();
return;
}
Fotografija f = new Fotografija(naziv, currentPhotoPath);
dbHelper.insertFotografija(f);
etNaziv.setText("");
osveziListu();
}
});
